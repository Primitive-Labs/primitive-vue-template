{
  "name": "primitive-vue-template",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm codegen && vite",
    "build": "pnpm codegen && run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "clean": "rm -rf dist && pnpm clean-modules",
    "clean-modules": "rm -rf node_modules pnpm-lock.yaml",
    "build-only": "vite build",
    "test": "pnpm codegen && vitest run",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix --cache",
    "format:check": "prettier --check src/",
    "format": "prettier --write src/",
    "cf-deploy": "node scripts/deploy.mjs",
    "codegen": "npx js-bao-codegen-v2 -i src/models/models.toml -o src/models && (! ls .primitive/sync/*/*/database-types/*.toml >/dev/null 2>&1 || primitive databases codegen -o src/types/generated) && (! ls .primitive/sync/*/*/workflows/*.toml >/dev/null 2>&1 || primitive workflows codegen -o src/types/generated/workflows) && pnpm format"
  },
  "dependencies": {
    "@lucide/vue": "^1.24.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-vue": "^8.6.0",
    "js-bao": "^0.5.1",
    "js-bao-wss-client": "^2.0.11",
    "lodash.debounce": "^4.0.8",
    "pinia": "^3.0.4",
    "primitive-app": "^3.0.10",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "3.9.5",
    "primitive-admin": "^1.0.60",
    "shadcn-vue": "^2.7.4",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7",
    "wrangler": "^4.110.0",
    "ws": "^8.19.0"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
