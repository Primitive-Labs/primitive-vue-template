{
  "name": "primitive-app-template",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm codegen && vite",
    "build": "pnpm codegen && run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "clean": "rm -rf dist && pnpm clean-modules",
    "clean-modules": "rm -rf node_modules pnpm-lock.yaml",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix --cache",
    "format:check": "prettier --check src/",
    "format": "prettier --write src/",
    "cf-deploy": "node scripts/deploy.mjs",
    "codegen": "npx js-bao-codegen-v2 -i src/models/models.toml -o src/models && pnpm format"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/types": "^12.0.0",
    "@tailwindcss/vite": "^4.2.3",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-vue": "^8.6.0",
    "js-bao": "^0.5.0",
    "js-bao-wss-client": "^1.4.5",
    "lodash.debounce": "^4.0.8",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "primitive-app": "link:../primitive-app",
    "reka-ui": "^2.9.6",
    "shadcn-vue": "^2.6.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.3",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.3",
    "primitive-admin": "^1.0.40",
    "typescript": "~6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.7",
    "wrangler": "^4.84.0"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
