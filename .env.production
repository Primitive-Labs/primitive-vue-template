# Set to your Primitive APP ID (Can be the same as development, or a separate production app id)
VITE_APP_ID=YOUR_APP_ID_GOES_HERE

# Which Primitive Servers to use (likely shouldn't change)
VITE_API_URL=https://primitiveapi.com
VITE_WS_URL=wss://primitiveapi.com

# App name displayed in the UI (login page, browser tab, etc.)
VITE_APP_NAME="Primitive Template App"

# OAuth / magic-link callback URL.
# A relative path resolves against the deployed origin, so it works without
# hard-coding your production domain. Set an absolute URL only if the callback
# must live on a fixed host different from where the app is served.
VITE_OAUTH_REDIRECT_URI=/oauth/callback

# Enable/disable the OAuth Proxy URL.  Typically you want this off for development and on in production.
VITE_ENABLE_AUTH_PROXY="true"

# Only show "warn" and worse logs in production
VITE_LOG_LEVEL="warn"
